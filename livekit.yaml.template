# LiveKit Server Configuration Template
# Run docker/generate-livekit-config.sh to produce livekit.yaml

webhook:
  api_key: ${LIVEKIT_API_KEY}
  urls:
    - https://mello.zenflows.in/api/v1/webhooks/livekit

rtc:
  tcp_port: 7881
  port_range_start: 50000
  port_range_end: 50200

logging:
  level: info
  json: true
